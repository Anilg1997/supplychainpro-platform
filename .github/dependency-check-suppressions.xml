<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd"
              xmlns:ns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- Suppress false positives -->

    <!-- Spring Boot starter dependencies -->
    <suppress>
        <notes>Spring Boot starter dependencies are not vulnerabilities</notes>
        <filePath regex="true">.*spring-boot-starter-.*\.jar</filePath>
        <cpe>cpe:/a:vmware:spring_framework</cpe>
    </suppress>

    <!-- Jackson databind false positives -->
    <suppress>
        <notes>Jackson databind CVEs are often false positives for modern versions</notes>
        <filePath regex="true">.*jackson-databind-.*\.jar</filePath>
        <cpe>cpe:/a:fasterxml:jackson-databind</cpe>
    </suppress>

    <!-- Netty false positives -->
    <suppress>
        <notes>Netty CVEs often don't apply to latest versions</notes>
        <filePath regex="true">.*netty-.*\.jar</filePath>
        <cpe>cpe:/a:netty:netty</cpe>
    </suppress>

    <!-- Logback false positives -->
    <suppress>
        <notes>Logback vulnerabilities often require specific configurations</notes>
        <filePath regex="true">.*logback-.*\.jar</filePath>
        <cpe>cpe:/a:qos:logback</cpe>
    </suppress>

    <!-- Test dependencies -->
    <suppress>
        <notes>Test dependencies are not deployed to production</notes>
        <filePath regex="true">.*test.*\.jar</filePath>
        <cpe>cpe:/a:testng:testng</cpe>
    </suppress>

    <!-- Lombok -->
    <suppress>
        <notes>Lombok is a compile-time annotation processor, not a runtime dependency</notes>
        <filePath regex="true">.*lombok-.*\.jar</filePath>
    </suppress>

</suppressions>

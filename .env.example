# ============================================
# SupplyChain Pro - Environment Variables
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SupplyChain@2024
POSTGRES_DB=supplychainpro
POSTGRES_PORT=5432

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=Mongo@2024
MONGO_PORT=27017

# --- Redis ---
REDIS_PASSWORD=Redis@2024
REDIS_PORT=6379

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# --- Service Registry ---
EUREKA_SERVER_URL=http://service-registry:8761/eureka

# --- JWT ---
JWT_SECRET=SupplyChainPro_JWT_Min32CharSecret_2024
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# --- Monitoring ---
ZIPKIN_PORT=9411
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
KAFKA_UI_PORT=8090
MONGO_EXPRESS_PORT=8091
PGADMIN_EMAIL=admin@supplychainpro.com
PGADMIN_PASSWORD=SupplyChain@2024
PGADMIN_PORT=5050

# --- Mail (mock) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# --- App Config ---
SPRING_PROFILES_ACTIVE=docker
JAVA_OPTS=-Xms256m -Xmx512m
